QDRANT_URL=http://qdrant:6333

# You can use DeepSeek or Qwen-compatible endpoints
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embedding model used by qdrant fastembed
# If you prefer, change to BAAI/bge-small-en-v1.5 or another supported model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
