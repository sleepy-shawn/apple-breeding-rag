__pycache__/
*.pyc
.env
.DS_Store
.venv-verify/
node_modules/
.next/
~$*.docx

# Large/local runtime data
backend/data/**
!backend/data/
!backend/data/README.md
!backend/data/genes/
!backend/data/genes/sample_genes.csv
!backend/data/genes/genes_firmness.csv
!backend/data/genes/genes_firmness_curated.csv
!backend/data/genes/genes_color_curated.csv
!backend/data/genes/genes_acidity_curated.csv
!backend/data/genes/genes_harvest_curated.csv
!backend/data/genes/genes_sugar_curated.csv
!backend/data/genes/genes_gdr_curated.csv
!backend/data/genes/genes_gdr_curated_*.csv

# Keep only the active workspace artifacts in git
workspace/default/**
!workspace/default/
!workspace/default/.gitkeep
!workspace/default/README.md
!workspace/default/evaluation/
!workspace/default/evaluation/.gitkeep
!workspace/default/evaluation/eval_protocol.md
!workspace/default/evaluation/test_questions.jsonl
!workspace/default/evaluation/runs/
!workspace/default/evaluation/runs/baseline_final_paper_set/
!workspace/default/evaluation/runs/baseline_final_paper_set/summary.md
!workspace/default/evaluation/runs/baseline_final_paper_set/summary.json
!workspace/default/evaluation/runs/baseline_final_paper_set/results.csv
!workspace/default/evaluation/runs/baseline_final_paper_set/run_manifest.json
!workspace/default/reports/
!workspace/default/reports/.gitkeep
!workspace/default/reports/backend_paper_inventory.csv
!workspace/default/reports/paper_inventory_summary.md
!workspace/default/reports/qtl_reference_system_audit.md
!workspace/default/**/.gitkeep
!workspace/README.md

# Local thesis and archive materials
archive/history/**
archive/school-materials/**
thesis/*.docx
thesis/*.pdf
thesis/*.xlsx
thesis/*.zip
